# Anthropic API 키 (Vision 분석에 필요)
ANTHROPIC_API_KEY=sk-ant-...

# Vision 분석 모델. 기본 claude-opus-4-8. 대량 분류 비용을 줄이려면
# claude-sonnet-4-6 또는 claude-haiku-4-5 로 교체 가능.
VISION_MODEL=claude-opus-4-8

# 임베딩 좌표 제공자: clip | taxonomy
#  - clip     : @huggingface/transformers 로 실제 CLIP 이미지 임베딩(별도 설치 필요)
#               `pnpm --filter @imgspace/server add @huggingface/transformers`
#               설치돼 있지 않으면 자동으로 taxonomy 로 폴백한다.
#  - taxonomy : Vision 점수에서 결정론적 특징 벡터 생성(추가 설치 불필요, 즉시 동작)
EMBED_PROVIDER=clip

# 서버 포트(기본 8790)
PORT=8790
